  m_Script: {fileID: 11500000, guid: dab40134f96b0c04e893ef68ca62f8c8, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::GameManager01
  dialogue_text01: {fileID: 757778554}
  character_text01: {fileID: 1057233936}
  dialogue01:
  - char_name: characterText
    dialogue_text: How do you know Time?
    options: []
  - char_name: Akira
    dialogue_text: Us Kitsune live for a very long time. I guess they found me interesting.
    options: []
  - char_name: Akira
    dialogue_text: I assume it piqued their interest when I was running around after
      becoming a Kitsune, stalking humans but never mustering up the courage to talk
      to them . . .
    options: []
  - char_name: characterText
    dialogue_text: "Why didn\u2019t you? Is it because of your shapeshifting?"
    options: []
  - char_name: Akira
    dialogue_text: It is . . . complicated . . .
    options: []
  - char_name: characterText
    dialogue_text: We can talk about it, I think my head is spinning less now-
    options: []
  - char_name: Time
    dialogue_text: Hello, Akira.
    options: []
  - char_name: Akira
    dialogue_text: 'Hello, Time. '
    options: []
  - char_name: Time
    dialogue_text: It is always a pleasure meeting with you. I will be taking our
      mortal here though.
    options: []
  - char_name: Akira
    dialogue_text: 'I see that my time with you is up. I hope to see you again soon. '
    options: []
  - char_name: characterText
    dialogue_text: Wait, my head JUST STOPPED SPIN-
    options: []
  line_index01: 0
  continue_button01: {fileID: 321424036}
  next_scene01: {fileID: 2000773201}
  pause_screen01: {fileID: 1608122806}
  journal01: {fileID: 260286457}
  image_enabler: {fileID: 1703015020}
