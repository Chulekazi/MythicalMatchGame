MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 596324320}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: dab40134f96b0c04e893ef68ca62f8c8, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::GameManager01
  dialogue_text01: {fileID: 32724199}
  character_text01: {fileID: 1222499950}
  dialogue01:
  - char_name: Chryseis
    dialogue_text: "I\u2019m centimetres away from you and I haven\u2019t eaten you,
      so I think you can trust that I won\u2019t eat you. "
    options: []
  - char_name: characterText
    dialogue_text: You think??
    options: []
  - char_name: Chryseis
    dialogue_text: 'Yep! '
    options: []
  - char_name: characterText
    dialogue_text: That does not inspire confidence.
    options: []
  - char_name: Chryseis
    dialogue_text: "You\u2019ll be fine! I promise!"
    options: []
  - char_name: characterText
    dialogue_text: "(I\u2019m even less convinced)"
    options: []
  - char_name: Chryseis
    dialogue_text: "Oh look at the time! Dad told me not to take up too much of your
      time because I\u2019d scare you off! Do you need to go?"
    options: []
  - char_name: characterText
    dialogue_text: I think so?
    options: []
  - char_name: characterText
    dialogue_text: "(Where\u2019s Time when you need them??)"
    options: []
  - char_name: Chryseis
    dialogue_text: "Okay, well I\u2019ll just send you up to the surface and pop
      that bubble around your head."
    options: []
  - char_name: characterText
    dialogue_text: Wait what-
    options: []
  - char_name: Chryseis
    dialogue_text: Bye bye! It was nice meeting you!!
    options: []
  - char_name: characterText
    dialogue_text: "Yeah I\u2019m gonna die. "
    options: []
  - char_name: Time
    dialogue_text: Do not worry mortal, I will be taking you to your next date now.
    options: []
  - char_name: characterText
    dialogue_text: "THERE\u2019S MORE??"
    options: []
  line_index01: 0
  continue_button01: {fileID: 778662702}
  next_scene01: {fileID: 1866777704}
  pause_screen01: {fileID: 364130201}
  journal01: {fileID: 308520088}
  image_enabler: {fileID: 1413157776}
