--- !u!114 &2071769533
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 2071769532}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: dab40134f96b0c04e893ef68ca62f8c8, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::GameManager01
  dialogue_text01: {fileID: 478752702}
  character_text01: {fileID: 1539818342}
  dialogue01:
  - char_name: Vikram
    dialogue_text: Regardless of your reasons, I do think it's endearing.
    options: []
  - char_name: characterText
    dialogue_text: Uh, uhm, thank you...
    options: []
  - char_name: Vikram
    dialogue_text: Flustered already? You make it too easy.
    options: []
  - char_name: characterText
    dialogue_text: I'm not!
    options: []
  - char_name: Vikram
    dialogue_text: That look on your face says otherwise, but I'll believe you.
    options: []
  - char_name: characterText
    dialogue_text: I, uh, I like the color of your clothes.
    options: []
  - char_name: Vikram
    dialogue_text: Thank you! Of course you do, these are some of the finest fabrics
      available, and I do love me some bold colours.
    options: []
  - char_name: characterText
    dialogue_text: I reckon they suit your personality...
    options: []
  - char_name: Vikram
    dialogue_text: You flatter me.
    options: []
  - char_name: characterText
    dialogue_text: (I don't know what to say here.)
    options: []
  - char_name: characterText
    dialogue_text: (Maybe I should've gone outside more)
    options: []
  - char_name: characterText
    dialogue_text: (Okay maybe not the time to have a crisis)
    options: []
  - char_name: characterText
    dialogue_text: I, uh-
    options: []
  - char_name: Vikram
    dialogue_text: Oh, I hear my name being called. Stay put, I will be right back.
    options: []
  - char_name: characterText
    dialogue_text: Uh, okay.
    options: []
  - char_name: Time
    dialogue_text: Time's up! Time for your next date!
    options: []
  - char_name: characterText
    dialogue_text: But he said he'll be right ba-
    options: []
