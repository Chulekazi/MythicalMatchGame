  dialogue01:
  - char_name: characterText
    dialogue_text: Sounds very . . . carefree.
    options: []
  - char_name: Chryseis
    dialogue_text: "I guess, but my siblings have responsibilities and stuff so I\u2019m
      really bored most of the time. "
    options: []
  - char_name: characterText
    dialogue_text: Ah . . . sorry about that . . .
    options: []
  - char_name: Chryseis
    dialogue_text: "It\u2019s okay, that\u2019s why you\u2019re here, right? That\u2019s
      what my dad told me."
    options: []
