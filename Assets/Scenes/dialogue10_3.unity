  dialogue01:
  - char_name: characterText
    dialogue_text: "Could you be more\u2026broad?"
    options: []
  - char_name: Chryseis
    dialogue_text: "We\u2019re in the ocean!"
    options: []
  - char_name: characterText
    dialogue_text: "\u2026which one\u2026"
    options: []
  - char_name: Chryseis
    dialogue_text: "Honestly, I\u2019m not too sure, but I know we\u2019re next to
      the Greek humans. "
    options: []
  - char_name: characterText
    dialogue_text: "That\u2026kinda helps\u2026"
