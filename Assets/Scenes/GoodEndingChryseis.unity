  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 19ed22f806f0b7d4396bc500ca5915ab, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::ManagerScript
  dialogueLines:
  - characterName: You
    dialogueText: I was initially very worried what living in water permanently would
      do to my body.
  - characterName: You
    dialogueText: 'However, I think Time has pulled some strings and made my body
      adapt better. '
  - characterName: You
    dialogueText: "I still can\u2019t breathe and need to depend on the bubble, but
      that\u2019s easy to deal with. "
  - characterName: You
    dialogueText: "I\u2019m still trying to learn all of Chryseis\u2019 siblings\u2019
      names, I think I\u2019m getting there . . ."
  - characterName: Chryseis
    dialogueText: BAAAAAABE, Coral and Bubbles are here!
  - characterName: You
    dialogueText: (Shoot, which siblings are those again?)
  nameTextUI: {fileID: 745425018}
  dialogueTextUI: {fileID: 1397188470}
  nextButton: {fileID: 1379209496}
  typingSpeed: 0.03
  audioSource: {fileID: 32637712}
  nextButtonSound: {fileID: 8300000, guid: b6af50e711a415342a292b50143fa5ff, type: 3}
  audioSource2: {fileID: 32637711}
