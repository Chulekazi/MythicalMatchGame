MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1107941416}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: dab40134f96b0c04e893ef68ca62f8c8, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::GameManager01
  dialogue_text01: {fileID: 776197352}
  character_text01: {fileID: 306166567}
  dialogue01:
  - char_name: characterText
    dialogue_text: "Surely I\u2019ll get used to this weird travelling method at
      some point right . . . eugh . . ."
    options: []
  - char_name: ???
    dialogue_text: 'Hello there. '
    options: []
  - char_name: characterText
    dialogue_text: "Oh, hello! I\u2019m sorry for anything that\u2019s going to come
      out of my mouth during this conversation, I am INCREDIBLY dizzy."
    options: []
  - char_name: ???
    dialogue_text: Please do not fuss about that, it is no problem.
    options: []
  - char_name: Akira
    dialogue_text: My name is Akira, and I am a Kitsune, pleasure to meet you.
    options: []
  - char_name: Akira
    dialogue_text: 'Time has already caught me up on the situation, I will try to
      be as accommodating as possible. '
    options: []
  - char_name: characterText
    dialogue_text: 'Wait you know Time? '
    options: []
  - char_name: Akira
    dialogue_text: "We have spoken on occasion. They trust that I will not speak
      of their existence since I am\u2026not one to regularly communicate with humans."
    options: []
  - char_name: characterText
    dialogue_text: 'So why the exception to talk to me, then? '
    options: []
  - char_name: Akira
    dialogue_text: I . . . prefer not to say . . . for now . . .
    options: []
  - char_name: characterText
    dialogue_text: Oh, okay. Uhm, so are you under the impression that this is a
      date then?
    options: []
  line_index01: 0
