--- !u!114 &2005503127
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 2005503126}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: dab40134f96b0c04e893ef68ca62f8c8, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::GameManager01
  dialogue_text01: {fileID: 912804481}
  character_text01: {fileID: 130762958}
  dialogue01:
  - char_name: ???
    dialogue_text: YOU'RE HEREEEEEE!
    options: []
  - char_name: characterText
    dialogue_text: 'Please don''t shout, I''m still dizzy . . . '
    options: []
  - char_name: ???
    dialogue_text: "Sorry! I just got really excited when dad said that he\u2019s
      found me a new friend!"
    options: []
  - char_name: characterText
    dialogue_text: (Friend? The last one seemed more like a date than a playdate
      . . .)
    options: []
  - char_name: characterText
    dialogue_text: 'Right, uh, I''m {playerName}, what''s your name? '
    options: []
  - char_name: Chryseis
    dialogue_text: "Chryseis! I can\u2019t WAIT to show you around, there\u2019s
      so much to see!!"
    options: []
  - char_name: characterText
    dialogue_text: 'Okay, how about we sit and talk for a bit before we start showing
      me things. '
    options: []
  - char_name: characterText
    dialogue_text: "(Also because my head\u2019s still spinning)"
    options: []
  - char_name: characterText
    dialogue_text: '. . . '
    options: []
  - char_name: characterText
    dialogue_text: Wait.
    options: []
  - char_name: characterText
    dialogue_text: Are we underwater right now??
    options: []
  - char_name: Chryseis
    dialogue_text: Well, yeah, where else would we be?
    options: []
  - char_name: characterText
    dialogue_text: How am I breathing right now??
    options: []
  - char_name: Chryseis
    dialogue_text: I put a bubble over your head, you should be fine.
    options: []
  - char_name: characterText
    dialogue_text: Should?? . . . oh god you have a fish tail.
    options: []
  - char_name: Chryseis
    dialogue_text: "Well yeah, I\u2019m a Siren? How else am I supposed to swim?"
    options: []
  - char_name: characterText
    dialogue_text: . . . I am realising the reality of my situation.
    options: []
  - char_name: Chryseis
    dialogue_text: Huh?
    options: []
  - char_name: characterText
    dialogue_text: "Don\u2019t worry about it."
    options: []
  - char_name: characterText
    dialogue_text: So, uh, what do you want to talk about?
    options: []
  line_index01: 0
  continue_button01: {fileID: 324988749}
  next_scene01: {fileID: 1328444839}
  pause_screen01: {fileID: 1650440377}
