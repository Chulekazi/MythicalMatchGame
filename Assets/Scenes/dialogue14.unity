  m_Script: {fileID: 11500000, guid: dab40134f96b0c04e893ef68ca62f8c8, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::GameManager01
  dialogue_text01: {fileID: 1753279292}
  character_text01: {fileID: 1684663904}
  dialogue01:
  - char_name: Akira
    dialogue_text: "I-\u2026 Yes\u2026I am aware of the nature of this interaction. "
    options: []
  - char_name: characterText
    dialogue_text: "Oh wow! I heard Kitsune are shapeshifters, but I didn\u2019t
      realise how effortless it would be for you!"
    options: []
  - char_name: Akira
    dialogue_text: 'It depends on us individually. I personally change my form depending
      on my emotions. Which makes it difficult to be in the presence of humans as
      I have to be very careful of my emotions, as to not reveal my identity. '
    options: []
  - char_name: characterText
    dialogue_text: 'Do you not like interacting with humans? '
    options: []
  - char_name: Akira
    dialogue_text: I adore them, actually. However, I am never brave enough to interact
      with them. I guess you could say that I am shy.
    options: []
  - char_name: characterText
    dialogue_text: "Me and you both, the difference is that I\u2019m also a human
      and still find it difficult to talk to them. "
    options: []
  line_index01: 0
