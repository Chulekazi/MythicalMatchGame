--- !u!114 &915656669
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 915656666}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 19ed22f806f0b7d4396bc500ca5915ab, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::ManagerScript
  dialogueLines:
  - characterName: You
    dialogueText: "It\u2019s been peaceful living with Akira."
  - characterName: You
    dialogueText: 'To help them with interacting with humans, we go down to the settlement
      once a week. '
  - characterName: You
    dialogueText: "Sometimes a child will see Akira\u2019s ears and be bewildered
      but me and Akira just giggle and walk on. "
  - characterName: You
    dialogueText: 'They have definitely been getting less nervous about it over time.
      They get chattier every time we go into town. '
  - characterName: You
    dialogueText: "They\u2019ve been talking to me more, too. I\u2019ve also been
      introducing them to the concept of contractions. "
  - characterName: You
    dialogueText: "They\u2019re still not great at them. "
  - characterName: Akira
    dialogueText: I heard that!
  - characterName: You
    dialogueText: Good!
  nameTextUI: {fileID: 578479541}
  dialogueTextUI: {fileID: 1467680433}
