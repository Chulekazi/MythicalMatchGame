  m_Script: {fileID: 11500000, guid: 19ed22f806f0b7d4396bc500ca5915ab, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::ManagerScript
  dialogueLines:
  - characterName: You
    dialogueText: 'Living with Vikram has been a new experience, to say the least. '
  - characterName: You
    dialogueText: "His family is loud and friendly and was not fazed at all by me
      and Vikram\u2019s relationship."
  - characterName: You
    dialogueText: "Today we\u2019re hosting a big dinner event to officially announce
      our relationship. "
  - characterName: You
    dialogueText: Vikram can be such a proud show off sometimes.
  - characterName: You
    dialogueText: "This life is definitely more glamorous than what I\u2019m used
      to. "
  - characterName: You
    dialogueText: 'But . . . '
  - characterName: You
    dialogueText: 'I think I like it here. '
  - characterName: Vikram
    dialogueText: Darling! The guests are here!
  nameTextUI: {fileID: 1114924922}
  dialogueTextUI: {fileID: 123260007}
